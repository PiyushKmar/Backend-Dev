const fs = require('fs');

try {
    fs.mkdirSync("newDirectory");
    console.log("newDirectory created successfully!");
} catch (err) {
    console.log("Error creating newDirectory:", err.message);
}   6

fs.mkdir("folders/folder1/folders2", { recursive: true }, (err) => {
    if (err) {
        console.log("Error creating nested directories:", err);
    } else {
        console.log("Directories created successfully!");
    }
});

fs.rm("newDirectory", { recursive: true }, (err) => {
    if (err) {
        console.log("Error removing directory:", err);
    } else {
        console.log("Directory removed successfully!");
    }
});
